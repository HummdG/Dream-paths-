// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Parent @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         Parent   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Application models
model Parent {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  passwordHash  String?   @map("password_hash")
  name          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  accounts          Account[]
  sessions          Session[]
  children          Child[]
  subscription      Subscription?
  pathSubscriptions PathSubscription[]
  parentAccessPins  ParentAccessPin[]
  calendarEvents    CalendarEvent[]

  @@map("parents")
}

model Child {
  id        String   @id @default(cuid())
  parentId  String   @map("parent_id")
  firstName String   @map("first_name")
  age       Int
  pathId    String?  @map("path_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  parent           Parent            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  path             Path?             @relation(fields: [pathId], references: [id])
  missionProgress  MissionProgress[]
  projects         Project[]
  heroCharacter    HeroCharacter?
  userSprites      UserSprite[]
  userLevels       UserLevel[]
  gameProjects     GameProject[]
  calendarEvents   CalendarEvent[]

  @@map("children")
}

// Hero character pixel art model
model HeroCharacter {
  id          String   @id @default(cuid())
  childId     String   @unique @map("child_id")
  name        String   @default("My Hero")
  pixelData   Json     @map("pixel_data")  // 16x16 array of colors
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("hero_characters")
}

model Path {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  ageRange    String   @map("age_range")
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  missions Mission[]
  children Child[]

  @@map("paths")
}

model Mission {
  id                       String   @id @default(cuid())
  pathId                   String   @map("path_id")
  sequenceNumber           Int      @map("sequence_number")
  title                    String
  storyIntro               String   @map("story_intro") @db.Text
  goal                     String   @db.Text
  stepsJson                Json     @map("steps_json")
  estimatedDurationMinutes Int      @map("estimated_duration_minutes")
  resourcesJson            Json?    @map("resources_json")
  unlockCondition          String?  @map("unlock_condition")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // Relations
  path            Path              @relation(fields: [pathId], references: [id], onDelete: Cascade)
  missionProgress MissionProgress[]

  @@unique([pathId, sequenceNumber])
  @@map("missions")
}

enum MissionStatus {
  LOCKED
  AVAILABLE
  COMPLETED
}

model MissionProgress {
  id          String        @id @default(cuid())
  childId     String        @map("child_id")
  missionId   String        @map("mission_id")
  status      MissionStatus @default(LOCKED)
  completedAt DateTime?     @map("completed_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  child   Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([childId, missionId])
  @@map("mission_progress")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
}

model Subscription {
  id                   String             @id @default(cuid())
  parentId             String             @unique @map("parent_id")
  status               SubscriptionStatus @default(TRIALING)
  planId               String             @map("plan_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PathSubscription {
  id                   String             @id @default(cuid())
  parentId             String             @map("parent_id")
  pathId               String             @map("path_id")   // e.g. 'computer_scientist'
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, pathId])
  @@map("path_subscriptions")
}

model ParentAccessPin {
  id        String    @id @default(cuid())
  parentId  String    @map("parent_id")
  pinHash   String    @map("pin_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("parent_access_pins")
}

// Analytics events tracking
model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventName String   @map("event_name")
  parentId  String?  @map("parent_id")
  childId   String?  @map("child_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventName])
  @@index([parentId])
  @@map("analytics_events")
}

// =============================================================================
// CODE PROJECT & PROGRESS MODELS
// =============================================================================

// A child's game project (their code + customizations)
model Project {
  id        String   @id @default(cuid())
  childId   String   @map("child_id")
  packId    String   @map("pack_id")  // e.g. "platformer_v1"
  name      String   @default("My Game")
  
  // Current progress tracking
  currentMissionId String  @map("current_mission_id")
  currentStepId    String  @map("current_step_id")
  
  // User's customization config (THEME, PLAYER, etc.)
  gameConfigJson   Json    @map("game_config_json")
  
  // Aggregated stats
  totalStars       Int     @default(0) @map("total_stars")
  badgesJson       Json    @default("[]") @map("badges_json")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  child           Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  stepProgress    StepProgress[]
  codeSnapshots   CodeSnapshot[]
  
  @@unique([childId, packId])
  @@index([childId])
  @@map("projects")
}

// Progress for each step within a mission
model StepProgress {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  missionId   String   @map("mission_id")
  stepId      String   @map("step_id")
  
  // Current code for this step
  currentCode String   @db.Text @map("current_code")
  
  // Status
  status      StepStatus @default(NOT_STARTED)
  
  // Stars earned for this step
  starsEarned Int       @default(0) @map("stars_earned")
  
  // Number of times code was run
  runCount    Int       @default(0) @map("run_count")
  
  // Number of times hint was viewed
  hintViews   Int       @default(0) @map("hint_views")
  
  // First and last completion timestamps
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, stepId])
  @@index([projectId])
  @@index([missionId])
  @@map("step_progress")
}

enum StepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// Code snapshots for version history
model CodeSnapshot {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  stepId      String   @map("step_id")
  
  // The code at this point
  code        String   @db.Text
  
  // What triggered this snapshot
  triggerType SnapshotTrigger @map("trigger_type")
  
  // Timestamp
  createdAt   DateTime @default(now()) @map("created_at")
  
  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId, stepId])
  @@index([createdAt])
  @@map("code_snapshots")
}

enum SnapshotTrigger {
  AUTO_SAVE      // Periodic auto-save
  MANUAL_SAVE    // User clicked save
  RUN_CODE       // Before running code
  STEP_COMPLETE  // When step is completed
  STEP_START     // When starting a step
}

// =============================================================================
// USER-CREATED CONTENT MODELS (Level Designer & Sprite Designer)
// =============================================================================

// User-created sprites (obstacles, enemies, items)
model UserSprite {
  id          String   @id @default(cuid())
  childId     String   @map("child_id")
  type        SpriteType
  name        String
  pixelData   Json     @map("pixel_data")  // 16x16 or 32x32 array of colors
  behavior    Json?    // For enemies: { type, speed, range, pattern }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([type])
  @@map("user_sprites")
}

enum SpriteType {
  OBSTACLE
  ENEMY
  ITEM
  DECORATION
}

// User-created levels
model UserLevel {
  id          String   @id @default(cuid())
  childId     String   @map("child_id")
  name        String
  theme       String   // 'space', 'jungle', 'city', etc.
  gridData    Json     @map("grid_data")   // 2D array of tile data
  objects     Json     // Array of placed objects with positions
  settings    Json     // { winCondition, difficulty, timeLimit, etc. }
  thumbnail   String?  // Base64 mini preview
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([theme])
  @@map("user_levels")
}

// Calendar events for parent scheduling
model CalendarEvent {
  id             String    @id @default(cuid())
  parentId       String    @map("parent_id")
  childId        String?   @map("child_id")
  title          String
  description    String?
  startAt        DateTime  @map("start_at")
  endAt          DateTime? @map("end_at")
  isDreampaths   Boolean   @default(false) @map("is_dreampaths")
  packId         String?   @map("pack_id")
  missionId      String?   @map("mission_id")
  emailReminder  Boolean   @default(true) @map("email_reminder")
  reminderSentAt DateTime? @map("reminder_sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  parent Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  child  Child?  @relation(fields: [childId], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([startAt])
  @@map("calendar_events")
}

// Game project that combines hero, levels, and sprites
model GameProject {
  id          String   @id @default(cuid())
  childId     String   @map("child_id")
  name        String   @default("My Game")
  heroId      String?  @map("hero_id")  // Reference to HeroCharacter
  levelIds    Json     @default("[]") @map("level_ids")   // Array of UserLevel IDs
  spriteIds   Json     @default("[]") @map("sprite_ids")  // Array of UserSprite IDs
  settings    Json?    // Game-wide settings
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@map("game_projects")
}